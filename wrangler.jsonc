{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "theorieexamenoefenen",
  "compatibility_date": "2025-01-01",
  "assets": {
    "directory": "./dist",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page"
  },
  "workers_dev": true,
  "routes": [
    { "pattern": "theorieexamenoefenen.net", "custom_domain": true },
    { "pattern": "www.theorieexamenoefenen.net", "custom_domain": true }
  ]
}
