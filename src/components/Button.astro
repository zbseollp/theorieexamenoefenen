---
interface Props {
  href?: string;
  variant?: "primary" | "secondary" | "ghost";
  class?: string;
  type?: "button" | "submit";
}
const { href, variant = "primary", class: cls = "", type = "button" } = Astro.props;
const base =
  "inline-flex items-center justify-center gap-2 rounded-xl px-5 py-3 text-base font-semibold transition focus-visible:outline-2 focus-visible:outline-offset-2";
const variants = {
  primary: "bg-brand-700 text-white hover:bg-brand-800 shadow-sm",
  secondary: "border border-brand-700 text-brand-700 hover:bg-brand-50",
  ghost: "text-brand-700 hover:bg-brand-50",
};
const klass = `${base} ${variants[variant]} ${cls}`;
const Tag = href ? "a" : "button";
---
{href ? (
  <a href={href} class={klass}><slot /></a>
) : (
  <button type={type} class={klass}><slot /></button>
)}
