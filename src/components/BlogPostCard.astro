---
import type { Post } from "@lib/posts";
import { displayTitle, readingMinutes } from "@lib/posts";
interface Props { post: Post; featured?: boolean }
const { post, featured = false } = Astro.props;
const { date } = post.data;
const title = displayTitle(post);
const href = `/${post.id}/`;
const dateStr = date.toLocaleDateString("nl-NL", { day: "numeric", month: "short", year: "numeric" });
---
{featured ? (
  <article class="group relative bg-orange-600 rounded-2xl overflow-hidden hover:bg-orange-700 transition-colors col-span-2">
    <a href={href} class="absolute inset-0 z-10" aria-label={title}></a>
    <div class="p-7 flex flex-col h-full min-h-[180px] justify-between">
      <div>
        <span class="inline-block text-xs font-bold text-orange-200 uppercase tracking-widest mb-3">Uitgelicht</span>
        <h2 class="text-xl font-black text-white leading-snug group-hover:text-orange-100 transition-colors">{title}</h2>
      </div>
      <div class="flex items-center justify-between mt-6">
        <span class="text-xs text-orange-300">{dateStr}</span>
        <span class="text-xs font-bold text-orange-200 group-hover:text-white transition-colors">Lees artikel →</span>
      </div>
    </div>
  </article>
) : (
  <article class="group relative flex flex-col bg-white rounded-xl border-l-4 border-l-orange-400 border border-gray-100 hover:border-l-orange-600 hover:shadow-sm transition-all">
    <a href={href} class="absolute inset-0 z-10" aria-label={title}></a>
    <div class="p-4 flex-1 flex flex-col justify-between">
      <h2 class="text-sm font-bold text-gray-900 leading-snug group-hover:text-orange-700 transition-colors">{title}</h2>
      <div class="mt-3 flex items-center justify-between">
        <span class="text-xs text-gray-400">{dateStr}</span>
        <span class="text-xs font-semibold text-orange-500 group-hover:text-orange-700 transition-colors">→</span>
      </div>
    </div>
  </article>
)}
