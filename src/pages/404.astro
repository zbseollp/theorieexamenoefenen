---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
---
<BaseLayout title="Pagina niet gevonden (404) | TheorieExamenOefenen" description="Deze pagina bestaat niet." noindex={true}>
  <Container class="max-w-2xl py-(--spacing-section) text-center">
    <p class="text-7xl font-black text-orange-500">404</p>
    <h1 class="mt-4 text-3xl font-black text-gray-900">Pagina niet gevonden</h1>
    <p class="mt-3 text-gray-600">Oeps — deze pagina bestaat niet (meer). Ga terug naar de homepage of bekijk alle artikelen.</p>
    <div class="mt-8 flex justify-center gap-3 flex-wrap">
      <a href="/" class="inline-flex items-center rounded-full bg-orange-600 px-6 py-2.5 text-sm font-bold text-white hover:bg-orange-700 transition-colors">Naar home</a>
      <a href="/blog/" class="inline-flex items-center rounded-full border border-orange-200 bg-orange-50 px-6 py-2.5 text-sm font-bold text-orange-700 hover:bg-orange-100 transition-colors">Alle artikelen</a>
    </div>
  </Container>
</BaseLayout>
