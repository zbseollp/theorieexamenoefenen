---
import { getCollection, render } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import BlogPostLayout from "@layouts/BlogPostLayout.astro";
import { SITE } from "@lib/site";
import { readingMinutes } from "@lib/posts";

export async function getStaticPaths() {
  const RESERVED = new Set(["home", "contact", "verkeersborden-oefenen", "blog"]);
  const CLEAN = /^[a-z0-9][a-z0-9-]*$/;
  const pages = (await getCollection("pages"))
    .filter((p) => CLEAN.test(p.id) && !RESERVED.has(p.id))
    .map((page) => ({ params: { slug: page.id }, props: { entry: page, kind: "page" } }));
  const posts = (await getCollection("blog", (p) => !p.data.draft))
    .filter((p) => CLEAN.test(p.id) && !RESERVED.has(p.id))
    .map((post) => ({ params: { slug: post.id }, props: { entry: post, kind: "post" } }));
  return [...pages, ...posts];
}

const { entry, kind } = Astro.props;
const { Content } = await render(entry);

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: SITE.url + "/" },
    { "@type": "ListItem", position: 2, name: entry.data.title, item: new URL(`/${entry.id}/`, SITE.url).href },
  ],
};
---
{kind === "post" ? (
  <BlogPostLayout post={entry} readMin={readingMinutes(entry.body)}>
    <Content />
  </BlogPostLayout>
) : (
  <BaseLayout title={entry.data.metaTitle || entry.data.title} description={entry.data.metaDescription}>
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} is:inline />
    <nav class="border-b border-slate-100" aria-label="Kruimelpad">
      <Container class="max-w-3xl py-2 text-sm text-slate-500">
        <a href="/" class="hover:text-brand-700">Home</a> <span class="mx-1">/</span> <span class="text-slate-700">{entry.data.title}</span>
      </Container>
    </nav>
    <section class="bg-[linear-gradient(180deg,var(--color-brand-50)_0%,#fff_55%)]">
      <Container class="max-w-3xl pt-(--spacing-section) pb-6">
        <h1 class="text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">{entry.data.title}</h1>
      </Container>
    </section>

    <Container class="max-w-3xl">
      <a href="/verkeersborden-oefenen/" class="flex items-center justify-between gap-4 rounded-2xl bg-brand-50 p-5 ring-1 ring-brand-100 transition hover:bg-brand-100">
        <div>
          <p class="font-bold text-slate-900">Direct oefenen?</p>
          <p class="text-sm text-slate-600">Test gratis je kennis met de verkeersbordenquiz — 20 vragen, geen account nodig.</p>
        </div>
        <span class="hidden shrink-0 rounded-xl bg-brand-700 px-5 py-2.5 text-sm font-semibold text-white sm:inline-block">Start de quiz →</span>
      </a>
    </Container>

    <Container class="max-w-3xl">
      <div class="article-prose pt-6">
        <Content />
      </div>

      <aside class="my-(--spacing-section) rounded-2xl border border-slate-200 bg-slate-50 p-6">
        <h2 class="text-lg font-bold text-slate-900">Populaire onderwerpen</h2>
        <ul class="mt-3 grid gap-2 sm:grid-cols-2">
          {SITE.popular.filter((i) => i.href !== `/${entry.id}/`).slice(0, 6).map((i) => (
            <li><a class="text-brand-700 hover:underline" href={i.href}>{i.label}</a></li>
          ))}
        </ul>
      </aside>
    </Container>
  </BaseLayout>
)}
