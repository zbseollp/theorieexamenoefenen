---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import BlogPostCard from "@components/BlogPostCard.astro";
import { getHomepagePosts } from "@lib/posts";

const posts = await getHomepagePosts();
---
<BaseLayout
  title="Alle artikelen | TheorieExamenOefenen"
  description="Tips, uitleg en oefenstof voor je CBR auto theorie-examen. Meer dan 100 artikelen over verkeersregels, examentips en rijbewijs."
>
  <div class="bg-orange-600 text-white">
    <Container class="py-10">
      <p class="text-xs font-bold uppercase tracking-widest text-orange-200 mb-2">TheorieExamenOefenen</p>
      <div class="flex items-end justify-between flex-wrap gap-4">
        <h1 class="text-4xl font-black tracking-tight">Alle artikelen</h1>
        <span class="bg-white/10 text-orange-100 text-xs font-semibold px-3 py-1 rounded-full border border-white/10">{posts.length} artikelen</span>
      </div>
    </Container>
  </div>

  <Container class="py-(--spacing-section)">
    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {posts.map((p) => <BlogPostCard post={p} />)}
    </div>
  </Container>
</BaseLayout>
