---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import BlogPostCard from "@components/BlogPostCard.astro";
import { getHomepagePosts } from "@lib/posts";
import { SITE } from "@lib/site";

const allHomePosts = await getHomepagePosts();
const recent = allHomePosts.slice(0, 7);
---
<BaseLayout title={`${SITE.name} — ${SITE.tagline}`} description={SITE.description}>

  <!-- Hero: donker, twee kolommen -->
  <section class="bg-stone-950 text-white">
    <Container class="py-16 md:py-24">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h1 class="text-5xl font-bold tracking-tight leading-tight sm:text-6xl lg:text-7xl">
            Slaag voor je<br/>
            <span class="text-orange-400">theorie&#8209;examen.</span>
          </h1>
          <p class="mt-6 text-stone-300 text-lg leading-relaxed max-w-md">
            Uitleg, oefenstof en tips voor het CBR auto theorie-examen. Gericht studeren zodat jij in één keer door komt.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/blog/" class="inline-flex items-center gap-2 bg-orange-600 hover:bg-orange-500 text-white font-bold px-6 py-3 rounded-lg text-sm transition-colors">
              Bekijk alle artikelen
            </a>
            <a href="/theorie-examen/" class="inline-flex items-center gap-2 text-stone-400 hover:text-white text-sm transition-colors self-center">
              Wat is het examen? →
            </a>
          </div>
        </div>

        <!-- Examen samenvatting als kaart -->
        <div class="bg-stone-900 rounded-2xl border border-stone-800 overflow-hidden">
          <div class="px-6 py-4 border-b border-stone-800">
            <p class="text-xs font-bold uppercase tracking-widest text-orange-500">CBR Auto Theorie-examen</p>
          </div>
          <div class="divide-y divide-stone-800">
            {[
              { label: "Aantal vragen", value: "65 meerkeuzevragen" },
              { label: "Slagingsnorm", value: "Minimaal 77% goed" },
              { label: "Maximaal fouten", value: "15 fouten toegestaan" },
              { label: "Examenduur", value: "45 minuten" },
              { label: "Geldigheid certificaat", value: "18 maanden" },
            ].map(({ label, value }) => (
              <div class="flex justify-between items-center px-6 py-3 gap-4">
                <span class="text-sm text-stone-500">{label}</span>
                <span class="text-sm font-semibold text-white text-right">{value}</span>
              </div>
            ))}
          </div>
          <div class="px-6 py-4 border-t border-stone-800">
            <a href="/theorie-examen/" class="text-xs font-semibold text-orange-500 hover:text-orange-400 transition-colors">
              Lees alles over het examen →
            </a>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- Recente artikelen -->
  <Container class="py-(--spacing-section)">
    <div class="flex items-end justify-between mb-8">
      <div>
        <h2 class="text-3xl font-bold text-slate-900">Artikelen & uitleg</h2>
        <p class="mt-1 text-sm text-slate-500">Tips, theorie en examenstrategie</p>
      </div>
      <a href="/blog/" class="text-sm font-semibold text-orange-600 hover:text-orange-700 hidden sm:block">
        Alle artikelen →
      </a>
    </div>
    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {recent[0] && <BlogPostCard post={recent[0]} featured={true} />}
      {recent.slice(1).map((p) => <BlogPostCard post={p} />)}
    </div>
    <div class="mt-6 text-center sm:hidden">
      <a href="/blog/" class="text-sm font-bold text-orange-600">Alle artikelen →</a>
    </div>
  </Container>

  <!-- Drie onderdelen van het examen -->
  <section class="bg-orange-50 border-y border-orange-100">
    <Container class="py-(--spacing-section)">
      <h2 class="text-2xl font-bold text-slate-900 mb-8">De drie onderdelen</h2>
      <div class="grid gap-4 sm:grid-cols-3">
        {[
          {
            nr: "01",
            title: "Kennis",
            body: "Verkeersregels, borden en voorschriften. Het grootste onderdeel — goed te halen met de juiste voorbereiding.",
          },
          {
            nr: "02",
            title: "Inzicht",
            body: "Situaties beoordelen en de juiste keuze maken. Vereist begrip van de regels, niet alleen kennis.",
          },
          {
            nr: "03",
            title: "Gevaarherkenning",
            body: "Gevaarlijke situaties tijdig zien op video. Het moeilijkste onderdeel met een eigen deelnorm.",
          },
        ].map(({ nr, title, body }) => (
          <div class="bg-white rounded-xl p-6 border border-orange-100">
            <span class="text-4xl font-bold text-orange-100 block mb-3 leading-none">{nr}</span>
            <h3 class="font-bold text-slate-900 mb-2 text-base">{title}</h3>
            <p class="text-sm text-slate-500 leading-relaxed">{body}</p>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <!-- FAQ -->
  <Container class="max-w-2xl py-(--spacing-section)">
    <h2 class="text-2xl font-bold text-slate-900 mb-6">Veelgestelde vragen</h2>
    <div class="space-y-2">
      {[
        { q: "Hoeveel vragen heeft het CBR theorie-examen?", a: "Het theorie-examen voor rijbewijs B bestaat uit 65 meerkeuzevragen, verdeeld over kennis, inzicht en gevaarherkenning." },
        { q: "Wat is de slagingsnorm?", a: "Minimaal 77% goed — dat betekent maximaal 15 fouten op 65 vragen. Elk onderdeel heeft ook een eigen minimum." },
        { q: "Hoe lang duurt het examen?", a: "45 minuten. Gevaarherkenning heeft een aparte tijdsbewaking. Extra tijd is mogelijk met een dyslexieverklaring." },
        { q: "Hoe bereid ik me het beste voor?", a: "Lees eerst alle theorie, oefen daarna met examenvragen en besteed extra aandacht aan gevaarherkenning. Dat onderdeel levert de meeste fouten op." },
        { q: "Hoe lang is mijn theorie-certificaat geldig?", a: "18 maanden. Binnen die periode moet je ook het praktijkexamen halen, anders vervalt het." },
      ].map(({ q, a }) => (
        <details class="group border border-slate-200 rounded-xl overflow-hidden">
          <summary class="flex cursor-pointer items-center justify-between px-5 py-4 text-sm font-semibold text-slate-900 list-none gap-4 hover:bg-slate-50 transition-colors">
            {q}
            <span class="text-orange-400 group-open:rotate-45 transition-transform shrink-0 text-xl leading-none font-light">+</span>
          </summary>
          <p class="px-5 pb-4 text-sm text-slate-500 leading-relaxed">{a}</p>
        </details>
      ))}
    </div>
  </Container>

  <!-- Bottom CTA: simpel, geen kopie van andere sites -->
  <section class="bg-orange-600">
    <Container class="py-12 text-center">
      <h2 class="text-2xl font-bold text-white mb-2">Meer dan 200 artikelen beschikbaar</h2>
      <p class="text-orange-100 text-sm mb-6">Van verkeersregels tot examenstrategie — alles op één plek.</p>
      <a href="/blog/" class="inline-flex items-center gap-2 bg-white text-orange-700 font-bold px-6 py-3 rounded-lg text-sm hover:bg-orange-50 transition-colors">
        Bekijk alle artikelen →
      </a>
    </Container>
  </section>

</BaseLayout>
