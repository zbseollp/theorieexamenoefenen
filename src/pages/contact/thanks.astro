---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
---
<BaseLayout title="Bedankt voor je bericht | TheorieExamenOefenen" description="Je bericht is verstuurd." noindex={true}>
  <Container class="max-w-2xl py-(--spacing-section) text-center">
    <div class="mx-auto grid h-16 w-16 place-items-center rounded-full bg-green-100 text-green-700 text-2xl">✓</div>
    <h1 class="mt-6 text-3xl font-black text-gray-900">Bedankt voor je bericht!</h1>
    <p class="mt-3 text-gray-600">We hebben je bericht ontvangen en nemen zo snel mogelijk contact op.</p>
    <div class="mt-8 flex justify-center gap-3 flex-wrap">
      <a href="/" class="inline-flex items-center rounded-full bg-orange-600 px-6 py-2.5 text-sm font-bold text-white hover:bg-orange-700 transition-colors">Terug naar home</a>
      <a href="/blog/" class="inline-flex items-center rounded-full border border-orange-200 bg-orange-50 px-6 py-2.5 text-sm font-bold text-orange-700 hover:bg-orange-100 transition-colors">Meer artikelen</a>
    </div>
  </Container>
</BaseLayout>
