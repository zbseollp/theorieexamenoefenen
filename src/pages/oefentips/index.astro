---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import BlogPostCard from "@components/BlogPostCard.astro";
import { getAllPosts } from "@lib/posts";

const allPosts = await getAllPosts();
const tipPosts = allPosts.slice(0, 6);
---
<BaseLayout
  title="Oefentips voor het theorie-examen | TheorieExamenOefenen"
  description="Slim studeren voor het CBR theorie-examen. Praktische oefentips, studieschema's en adviezen voor gevaarherkenning."
>
  <div class="bg-orange-600 text-white">
    <Container class="py-14">
      <h1 class="text-4xl font-black tracking-tight">Oefentips</h1>
      <p class="mt-3 text-orange-100 max-w-xl">Slim studeren voor het theorie-examen. Zo haal je het in één keer.</p>
    </Container>
  </div>

  <Container class="max-w-3xl py-(--spacing-section)">
    <div class="article-prose">
      <h2>Begin met de theorie</h2>
      <p>
        Veel mensen starten direct met oefenvragen, maar het is beter om eerst de theorie goed te begrijpen. Lees de officiële ANWB Verkeersregels of gebruik onze artikelen om de basisregels te leren. Daarna beklijven de oefenvragen veel beter.
      </p>

      <h2>Plan je studie</h2>
      <p>
        Verspreid je voorbereiding over meerdere weken. Een goed basisschema:
      </p>
      <ul>
        <li><strong>Week 1–2:</strong> Theorie lezen — verkeersregels, borden, rijbaanmarkering</li>
        <li><strong>Week 3–4:</strong> Oefenvragen maken — minstens 200–300 vragen</li>
        <li><strong>Week 5:</strong> Focussen op zwakke punten en gevaarherkenning</li>
        <li><strong>Dag voor het examen:</strong> Rust houden, geen nieuwe stof</li>
      </ul>

      <h2>Train gevaarherkenning apart</h2>
      <p>
        Gevaarherkenning is het moeilijkste onderdeel en vraagt een aparte aanpak. Klik niet te snel (false positives tellen mee) maar ook niet te laat. Oefen met de officiële CBR-oefenomgeving en let op:
      </p>
      <ul>
        <li>Kruispunten met onduidelijke voorrang</li>
        <li>Voetgangers die de weg oversteken</li>
        <li>Fietsers op onverwachte plekken</li>
        <li>Auto's die plotseling afslaan of remmen</li>
      </ul>

      <h2>Veelgemaakte fouten</h2>
      <p>
        Dit zijn de meest gemaakte fouten op het theorie-examen:
      </p>
      <ul>
        <li>Voorrangsregels bij kruispunten (rechts voor links, borden)</li>
        <li>Rijstrookregels op de snelweg</li>
        <li>Maximumsnelheid in bebouwde kom (ook bij schoolzones)</li>
        <li>Inhaalverboden en -regels</li>
        <li>Te laat of te vroeg klikken bij gevaarherkenning</li>
      </ul>

      <h2>Op de dag van het examen</h2>
      <p>
        Kom op tijd aan — reken op 15 minuten voor aanvang. Neem je identiteitsbewijs mee. Lees elke vraag goed en neem de tijd. Je hebt gemiddeld 40 seconden per vraag, dus er is geen haast.
      </p>
    </div>
  </Container>

  {tipPosts.length > 0 && (
    <section class="border-t border-orange-100 bg-orange-50">
      <Container class="py-(--spacing-section)">
        <p class="text-xs font-bold uppercase tracking-widest text-orange-500 mb-2">Meer lezen</p>
        <h2 class="text-2xl font-black text-gray-900 mb-6">Recente artikelen</h2>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {tipPosts.map((p) => <BlogPostCard post={p} />)}
        </div>
        <div class="mt-6 text-center">
          <a href="/blog/" class="inline-flex items-center rounded-full bg-orange-600 px-7 py-3 text-sm font-bold text-white hover:bg-orange-700 transition-colors">Alle artikelen bekijken →</a>
        </div>
      </Container>
    </section>
  )}
</BaseLayout>
