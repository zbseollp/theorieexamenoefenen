---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import BlogPostCard from "@components/BlogPostCard.astro";
import { formatDate, postDescription, readingMinutes, getRelatedPosts, displayTitle, type Post } from "@lib/posts";
import { SITE } from "@lib/site";

interface Props { post: Post; readMin?: number }
const { post, readMin = 3 } = Astro.props;
const { date, featuredImage, featuredImageAlt } = post.data;
const title = displayTitle(post);
const related = await getRelatedPosts(post, 3);
const desc = postDescription(post);

const jsonld = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  datePublished: date.toISOString(),
  description: desc,
  image: featuredImage ? new URL(featuredImage, SITE.url).href : undefined,
  author: { "@type": "Organization", name: SITE.name },
  publisher: { "@type": "Organization", name: SITE.name },
  mainEntityOfPage: new URL(`/${post.id}/`, SITE.url).href,
};
---
<BaseLayout title={post.data.metaTitle || title} description={desc} type="article" image={featuredImage}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonld)} is:inline />
  <article>
    <!-- Breadcrumb + titel header -->
    <div class="bg-orange-50 border-b border-orange-100">
      <Container class="max-w-3xl pt-8 pb-8">
        <nav class="text-sm text-gray-500 mb-4">
          <a href="/blog/" class="hover:text-orange-600 transition-colors">Artikelen</a>
          <span class="mx-2 text-gray-300">/</span>
          <span class="text-gray-700 line-clamp-1">{title}</span>
        </nav>
        <h1 class="text-3xl font-black tracking-tight text-gray-900 sm:text-4xl leading-tight">{title}</h1>
        <div class="mt-3 flex items-center gap-3 text-sm text-gray-500">
          <span class="inline-flex items-center gap-1.5 bg-orange-100 text-orange-700 px-3 py-1 rounded-full text-xs font-semibold">
            <time datetime={date.toISOString()}>{formatDate(date)}</time>
          </span>
          <span class="text-gray-400">·</span>
          <span>{readMin} min lezen</span>
        </div>
      </Container>
    </div>

    {featuredImage && (
      <Container class="max-w-4xl">
        <img src={featuredImage} alt={featuredImageAlt || title} width="1200" height="630"
             loading="eager" fetchpriority="high" decoding="sync"
             class="mt-6 aspect-[16/9] w-full rounded-2xl object-cover" />
      </Container>
    )}

    <Container class="max-w-3xl">
      <div class="rounded-2xl bg-orange-50 border border-orange-100 p-5 my-8 flex items-start gap-4">
        <div class="text-2xl shrink-0">✅</div>
        <div>
          <p class="text-sm font-bold text-orange-900 mb-1">Klaar om te oefenen?</p>
          <p class="text-sm text-orange-800">Bekijk alle <a href="/blog/" class="underline font-semibold hover:text-orange-600">artikelen en oefentips</a> voor je theorie-examen.</p>
        </div>
      </div>
      <div class="article-prose pb-(--spacing-section)">
        <slot />
      </div>
    </Container>
  </article>

  {related.length > 0 && (
    <section class="border-t border-gray-100 bg-orange-50">
      <Container class="py-(--spacing-section)">
        <p class="text-xs font-bold uppercase tracking-widest text-orange-500 mb-2">Meer lezen</p>
        <h2 class="text-2xl font-black text-gray-900 mb-6">Gerelateerde artikelen</h2>
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {related.map((p) => <BlogPostCard post={p} />)}
        </div>
      </Container>
    </section>
  )}
</BaseLayout>
